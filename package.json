{
  "name": "promptpacker-vscode",
  "displayName": "PromptPacker",
  "description": "Combine files and folders into a single AI-ready prompt. Not on the Marketplace — clone and build from source: https://github.com/KhairatMouhcine/PromptPacker",
  "version": "0.2.0",
  "author": "Mouhcine KHAIRAT",
  "publisher": "mouhcinekhairat",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KhairatMouhcine/PromptPacker"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:promptpacker.addToPromptPacker",
    "onCommand:promptpacker.openPanel",
    "onCommand:promptpacker.clearAll"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptpacker.addToPromptPacker",
        "title": "Add to PromptPacker"
      },
      {
        "command": "promptpacker.openPanel",
        "title": "PromptPacker: Open Panel"
      },
      {
        "command": "promptpacker.clearAll",
        "title": "PromptPacker: Clear All Files"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "promptpacker.addToPromptPacker",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "mammoth": "^1.6.0",
    "jszip": "^3.10.1",
    "exceljs": "^4.4.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/pdf-parse": "^1.1.4",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
